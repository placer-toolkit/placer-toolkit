---
import { getCollection } from "astro:content";

import {
    getLanguageFromURL,
    useTranslations,
    useTranslatedPath,
} from "../../i18n/utilities.js";

import fs from "node:fs";
import path from "node:path";

import Heading from "../Heading.astro";

const language = getLanguageFromURL(Astro.url);
const translation = useTranslations(language);
const translatePath = useTranslatedPath(language);

const allComponents = await getCollection("docs", ({ id }: { id: string }) => {
    if (language !== "en") {
        return id.startsWith(`${language}/components/`);
    }

    return id.startsWith("components/");
});

const categoryKeys = [
    ...new Set(
        allComponents.map(
            (category: (typeof allComponents)[number]) =>
                category.data.category,
        ),
    ),
].sort();

const getIcon = (slug: string) => {
    const iconPath = path.join(
        process.cwd(),
        "src/assets/catalog/components",
        `${slug}.svg`,
    );

    try {
        return fs.readFileSync(iconPath, "utf8");
    } catch {
        return `
            <svg xmlns="http://www.w3.org/2000/svg" width="50" height="64" viewBox="0 0 50 50" fill="none">
                <path
                    d="M1 7C1 3.68629 3.68629 1 7 1H43C46.3137 1 49 3.68629 49 7V43C49 46.3137 46.3137 49 43 49H7C3.68629 49 1 46.3137 1 43V7Z"
                    stroke="var(--pc-color-surface-border)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-dasharray="6 6"
                />
                <path
                    d="M14.1566 18.7199L21.5367 16.7424C22.6036 16.4565 23.7003 17.0896 23.9862 18.1566L26.8463 28.8306C27.1322 29.8975 26.499 30.9942 25.4321 31.2801L18.052 33.2576C16.985 33.5435 15.8884 32.9103 15.6025 31.8434L12.7424 21.1694C12.4565 20.1024 13.0897 19.0057 14.1566 18.7199Z"
                    stroke="var(--pc-color-neutral-border-normal)"
                    stroke-width="2"
                />
                <path
                    d="M33.8449 16.3273H26.2045C23.9953 16.3273 22.2045 18.1181 22.2045 20.3273V31.3778C22.2045 33.587 23.9953 35.3778 26.2045 35.3778H33.8449C36.0541 35.3778 37.8449 33.587 37.8449 31.3778V20.3273C37.8449 18.1181 36.0541 16.3273 33.8449 16.3273Z"
                    fill="var(--pc-color-neutral-border-normal)"
                    stroke="var(--pc-color-surface-default)"
                    stroke-width="2"
                />
            </svg>
        `;
    }
};
---

{categoryKeys.map((category) => (
    <>
        <Heading level="2">{translation(`catalog.components.${category}`)}</Heading>

        <div class="catalog-grid">
            {allComponents
                .filter(
                    (cat: (typeof allComponents)[number]) => cat.data.category === category,
                )
                .sort(
                    (
                        a: (typeof allComponents)[number],
                        b: (typeof allComponents)[number],
                    ) => a.data.title.localeCompare(b.data.title),
                )
                .map((item: (typeof allComponents)[number]) => {
                    const rawID = item.slug || item.id || "";
                    const slug = rawID.split("/").pop()?.replace(/\.(mdx|md)$/, "") || "unknown";

                    return (
                        <a href={translatePath(`/docs/components/${slug}`)} class="catalog-item">
                            <pc-card>
                                <div slot="media" class="icon-wrapper">
                                    <Fragment set:html={getIcon(slug)} />
                                </div>
                                <div class="catalog-title">{item.data.title}</div>
                            </pc-card>
                        </a>
                    );
                })
            }
        </div>
    </>
))}
