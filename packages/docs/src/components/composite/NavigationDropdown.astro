<pc-popup
    class="navigation-dropdown"
    placement="bottom-end"
    distance="0"
    skidding="0"
    flip-fallback-strategy="best-fit"
    shift-padding="10"
    auto-size="vertical"
    auto-size-padding="10"
    shift
    flip
>
    <div slot="anchor">
        <slot name="trigger" />
    </div>

    <div class="dropdown-menu">
        <ul>
            <slot />
        </ul>
    </div>
</pc-popup>

<script>
    import { animateTo, stopAnimations } from "../internal/animate.js";
    import {
        getAnimation,
        setDefaultAnimation,
    } from "placer-toolkit/dist/utilities/animation-registry.js";
    import type { PcButton } from "placer-toolkit/dist/components/button/button.js";
    import type { PcPopup } from "placer-toolkit/dist/components/popup/popup.js";

    setDefaultAnimation("navigation-dropdown.show", {
        keyframes: [
            {
                offset: 0,
                opacity: 0,
                transform:
                    "scaleY(0.35) scaleX(0.95) translateY(-10px) rotate(1deg)",
            },
            {
                offset: 0.25,
                opacity: 1,
                transform:
                    "scaleY(1.03) scaleX(1.005) translateY(2px) rotate(-0.5deg)",
            },
            {
                offset: 0.5,
                transform:
                    "scaleY(0.995) scaleX(0.999) translateY(-0.5px) rotate(0.1deg)",
            },
            {
                offset: 0.75,
                transform:
                    "scaleY(1.002) scaleX(1.0005) translateY(0.2px) rotate(-0.05deg)",
            },
            {
                offset: 1,
                opacity: 1,
                transform: "scaleY(1) scaleX(1) translateY(0) rotate(0deg)",
            },
        ],
        options: {
            duration: 1000,
            easing: "cubic-bezier(0.2, 0.8, 0.2, 1)",
            fill: "forwards",
        },
    });

    setDefaultAnimation("navigation-dropdown.hide", {
        keyframes: [
            {
                offset: 0,
                opacity: 1,
                transform: "scaleY(1) scaleX(1) translateY(0) rotate(0deg)",
            },
            {
                offset: 0.15,
                transform:
                    "scaleY(1.005) scaleX(1.001) translateY(0.5px) rotate(-0.002deg)",
            },
            {
                offset: 0.4,
                transform:
                    "scaleY(0.99) scaleX(0.998) translateY(-1px) rotate(0.008deg)",
            },
            {
                offset: 0.75,
                transform:
                    "scaleY(0.6) scaleX(0.9) translateY(10px) rotate(0.007deg)",
            },
            {
                offset: 1,
                opacity: 0,
                transform:
                    "scaleY(0.3) scaleX(0.8) translateY(25px) rotate(0.01deg)",
            },
        ],
        options: {
            duration: 400,
            easing: "cubic-bezier(0.6, 0.05, 0.8, 0.2)",
            fill: "forwards",
        },
    });

    document.addEventListener("astro:page-load", () => {
        const popups = document.querySelectorAll<PcPopup>(
            ".navigation-dropdown",
        );

        if (!popups) {
            return;
        }

        popups.forEach((popup) => {
            if (!popup) {
                return;
            }

            const triggerButton = popup.querySelector<PcButton>("pc-button");
            const internalTrigger =
                triggerButton?.shadowRoot?.querySelector("button");
            const menu = popup.querySelector<HTMLDivElement>(".dropdown-menu");

            internalTrigger?.setAttribute("aria-haspopup", "true");
            internalTrigger?.setAttribute("aria-expanded", "false");

            const links = Array.from(menu?.querySelectorAll("a") ?? []);

            async function showMenu() {
                if (!popup) {
                    return;
                }

                document.addEventListener(
                    "pointerdown",
                    handleDocumentPointerDown,
                );

                if (!menu || !triggerButton) {
                    return;
                }

                popup.active = true;

                internalTrigger?.setAttribute("aria-expanded", "true");

                links[0]?.focus();

                const { keyframes, options } = getAnimation(
                    menu,
                    "navigation-dropdown.show",
                    {
                        dir: "ltr",
                    },
                );

                await animateTo(menu, keyframes, options);
                await stopAnimations(menu);

                document.addEventListener("keydown", handleDocumentKeyDown);
            }

            async function hideMenu() {
                if (!menu) {
                    return;
                }

                const { keyframes, options } = getAnimation(
                    menu,
                    "navigation-dropdown.hide",
                    {
                        dir: "ltr",
                    },
                );

                await animateTo(menu, keyframes, options);
                await stopAnimations(menu);

                popup.active = false;

                internalTrigger?.setAttribute("aria-expanded", "false");

                triggerButton?.focus();

                document.removeEventListener(
                    "pointerdown",
                    handleDocumentPointerDown,
                );
                document.removeEventListener("keydown", handleDocumentKeyDown);
            }

            function toggleMenu() {
                if (!popup) {
                    return;
                }

                if (popup.active) {
                    hideMenu();
                } else {
                    showMenu();
                }
            }

            function handleDocumentKeyDown(event: KeyboardEvent) {
                if (event.key === "Escape") {
                    event.preventDefault();
                    hideMenu();
                }
            }

            function handleDocumentPointerDown(event: PointerEvent) {
                const isClickInside = popup.contains(event.target as Node);

                if (!isClickInside) {
                    hideMenu();
                }
            }

            triggerButton?.addEventListener("click", toggleMenu);

            links.forEach((link) => {
                link.addEventListener("click", () => {
                    hideMenu();
                });
            });
        });
    });
</script>

<style>
    .navigation-dropdown[data-current-placement^="top"] .dropdown-menu {
        transform-origin: bottom;
    }

    .navigation-dropdown[data-current-placement^="bottom"] .dropdown-menu {
        transform-origin: top;
    }

    .navigation-dropdown[data-current-placement^="left"] .dropdown-menu {
        transform-origin: right;
    }

    .navigation-dropdown[data-current-placement^="right"] .dropdown-menu {
        transform-origin: left;
    }

    .navigation-dropdown[data-current-placement="left-start"] .dropdown-menu {
        transform-origin: right top;
    }

    .navigation-dropdown[data-current-placement="left-end"] .dropdown-menu {
        transform-origin: right bottom;
    }

    .navigation-dropdown[data-current-placement="right-start"] .dropdown-menu {
        transform-origin: left top;
    }

    .navigation-dropdown[data-current-placement="right-end"] .dropdown-menu {
        transform-origin: left bottom;
    }

    .navigation-dropdown .dropdown-menu {
        display: flex;
        flex-direction: column;
        margin: 0;
        padding: 0.25em;
        inline-size: max-content;
        max-inline-size: var(--auto-size-available-width) !important;
        max-block-size: var(--auto-size-available-height) !important;
        background-color: var(--pc-color-surface-raised);
        color: var(--pc-color-text-normal);
        border: var(--pc-border-width-s) var(--pc-border-style)
            var(--pc-color-surface-border);
        border-radius: calc(var(--pc-border-radius-m) + 0.25em);
        text-align: start;
        user-select: none;
        overflow: auto;
        box-shadow: var(--pc-shadow-m);
    }

    .navigation-dropdown .dropdown-menu ul {
        margin-inline-start: 0;
        list-style-type: none;
    }
</style>
