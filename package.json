{
    "name": "placer-toolkit-monorepo",
    "private": true,
    "scripts": {
        "dev:toolkit": "pnpm --filter placer-toolkit dev",
        "dev:docs": "pnpm --filter docs dev",
        "dev": "pnpm -r --parallel dev",
        "build:toolkit": "pnpm --filter placer-toolkit build",
        "build:docs": "pnpm --filter docs build",
        "build": "pnpm build:toolkit && pnpm build:docs",
        "preview": "pnpm --filter docs preview",
        "astro": "pnpm --filter docs astro",
        "prepare": "husky",
        "release:toolkit": "pnpm --filter placer-toolkit publish --access public"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,html,css,md,mdx}": [
            "pnpm prettier --write"
        ]
    },
    "devDependencies": {
        "husky": "^9.1.7"
    },
    "dependencies": {
        "lint-staged": "^16.4.0"
    }
}
